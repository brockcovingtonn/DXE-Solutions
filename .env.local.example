# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and will never be committed.

# Supabase - found in Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key - found in Project Settings > API (under "service_role")
# KEEP THIS SECRET. Never expose it to the browser or commit it.
# Used only in server-side admin API routes to create new client logins.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend - found in your Resend dashboard under API Keys
RESEND_API_KEY=re_your_api_key_here

# Email address that receives estimate request submissions
ESTIMATE_NOTIFICATION_EMAIL=dixie@dxesolutions.com

# The "from" address Resend will send as.
# Must be on a domain you've verified in Resend, or use onboarding@resend.dev for testing
RESEND_FROM_EMAIL=onboarding@resend.dev

# Your site's live URL. Used to build links inside notification emails
# (e.g. "View project" buttons). Set this to your real domain in production.
NEXT_PUBLIC_SITE_URL=https://www.dxesolutions.com
